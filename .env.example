# Data Collectors 環境變數設定
# 複製此檔案為 .env 並填入實際值

# ============================================================
# TDX API（必填）
# 申請：https://tdx.transportdata.tw/
# ============================================================
TDX_APP_ID=your_tdx_app_id
TDX_APP_KEY=your_tdx_app_key

# ============================================================
# CWA 氣象局 API（選填）
# 申請：https://opendata.cwa.gov.tw/
# ============================================================
# CWA_API_KEY=your_cwa_api_key

# ============================================================
# 收集器設定
# ============================================================
# YouBike 城市（逗號分隔）
YOUBIKE_CITIES=Taipei,NewTaipei,Taoyuan

# YouBike 收集間隔（分鐘）
YOUBIKE_INTERVAL=15

# 氣象站收集間隔（分鐘）
# WEATHER_INTERVAL=60

# VD 車輛偵測器城市（逗號分隔）
VD_CITIES=Taipei,NewTaipei

# VD 收集間隔（分鐘）
VD_INTERVAL=5

# 溫度網格收集間隔（分鐘）
TEMPERATURE_INTERVAL=60

# 路邊停車城市（逗號分隔）
# 支援：Taipei, NewTaipei, Taichung（高雄不支援）
PARKING_CITIES=Taipei,NewTaipei,Taichung

# 路邊停車收集間隔（分鐘）
PARKING_INTERVAL=15

# 台鐵即時列車收集間隔（分鐘）
TRA_TRAIN_INTERVAL=2

# 台鐵靜態資料收集間隔（分鐘，1440=每日一次）
TRA_STATIC_INTERVAL=1440

# 航運 - TDX 國內航線船位（每 2 分鐘）
SHIP_TDX_ENABLED=true
SHIP_TDX_INTERVAL=2

# 航運 - 航港局 AIS 全船型追蹤（每 2 分鐘）
SHIP_AIS_ENABLED=true
SHIP_AIS_INTERVAL=2

# OpenSky 台灣空域快照（每 5 分鐘）
# 匿名可用，帶帳號可提升至 5 秒解析度 + 4,000 credits/天
# 申請：https://opensky-network.org/
# FR24 Zone 空域快照（公開 feed，無需 API key，每 5 分鐘）
FLIGHT_FR24_ZONE_ENABLED=false
# FLIGHT_FR24_ZONE_INTERVAL=5
# bbox 可個別調整（FR24 免費，可比 OpenSky 範圍大）
# FLIGHT_FR24_ZONE_LAMIN=21
# FLIGHT_FR24_ZONE_LAMAX=27
# FLIGHT_FR24_ZONE_LOMIN=117
# FLIGHT_FR24_ZONE_LOMAX=123

# OpenSky 台灣空域快照（每 5 分鐘）
FLIGHT_OPENSKY_ENABLED=false
# FLIGHT_OPENSKY_INTERVAL=5
# OAuth2 認證（新帳號，從 Account 頁面取得 API Client）
# FLIGHT_OPENSKY_CLIENT_ID=your-api-client
# FLIGHT_OPENSKY_CLIENT_SECRET=your_client_secret
# Basic Auth（舊帳號，二擇一即可）
# FLIGHT_OPENSKY_USERNAME=your_opensky_username
# FLIGHT_OPENSKY_PASSWORD=your_opensky_password

# ============================================================
# S3 儲存（建議生產環境設定）
# ============================================================
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_REGION=ap-northeast-1

# MinIO 或其他 S3 相容服務
# S3_ENDPOINT=https://minio.example.com

# ============================================================
# 通知設定（選填）
# ============================================================
# Webhook（支援 Discord、Slack 等）
# WEBHOOK_URL=https://discord.com/api/webhooks/xxx

# LINE Notify
# LINE_TOKEN=your_line_notify_token

# ============================================================
# HTTP API（下載資料用）
# ============================================================
# API Key（必填才會啟動 API Server）
# 建議使用隨機字串，例如：openssl rand -hex 32
API_KEY=your_api_key_here

# API 端口（預設 8080）
# API_PORT=8080

# ============================================================
# 其他
# ============================================================
# DEBUG=true
# LOG_LEVEL=DEBUG
