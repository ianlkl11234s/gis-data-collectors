# Data Collectors 環境變數設定
# 複製此檔案為 .env 並填入實際值

# ============================================================
# TDX API（必填）
# 申請：https://tdx.transportdata.tw/
# ============================================================
TDX_APP_ID=your_tdx_app_id
TDX_APP_KEY=your_tdx_app_key

# ============================================================
# CWA 氣象局 API（選填）
# 申請：https://opendata.cwa.gov.tw/
# ============================================================
# CWA_API_KEY=your_cwa_api_key

# ============================================================
# 環境部 MOENV API（空氣品質，選填）
# 公開 key 可直接使用，專屬申請：https://data.moenv.gov.tw/
# ============================================================
# MOENV_API_KEY=your_moenv_api_key

# 空氣品質系列 collector 預設為 false（多實例部署：只在一個實例打開即可）
# 空氣品質 - airtw 全台色階圖 PNG（無需 API key，每小時）
# AIR_QUALITY_IMAGERY_ENABLED=true
# AIR_QUALITY_IMAGERY_INTERVAL=60
# AIR_QUALITY_IMAGERY_PRODUCTS=AQI,PM25,PM10,O3,NO2

# 空氣品質 - 環境部 77 站即時觀測（需 MOENV_API_KEY，每小時）
# AIR_QUALITY_ENABLED=true
# AIR_QUALITY_INTERVAL=60

# 空氣品質 - LASS AirBox 微型感測器（無需 API key，每 5 分鐘）
# AIR_QUALITY_MICROSENSORS_ENABLED=true
# AIR_QUALITY_MICROSENSORS_INTERVAL=5
# AIR_QUALITY_MICROSENSORS_PM25_OUTLIER=500

# ============================================================
# 收集器設定
# ============================================================
# YouBike 城市（逗號分隔）
YOUBIKE_CITIES=Taipei,NewTaipei,Taoyuan

# YouBike 收集間隔（分鐘）
YOUBIKE_INTERVAL=15

# 氣象站收集間隔（分鐘）
# WEATHER_INTERVAL=60

# 地震報告收集（需要 CWA API Key，每日一次）
EARTHQUAKE_ENABLED=true
# EARTHQUAKE_INTERVAL=1440

# VD 車輛偵測器城市（逗號分隔）
VD_CITIES=Taipei,NewTaipei

# VD 收集間隔（分鐘）
VD_INTERVAL=5

# ============================================================
# 公車即時位置（TDX Bus/RealTimeByFrequency）
# 預設涵蓋全台 22 縣市：
#   直轄市 (6): Taipei, NewTaipei, Taoyuan, Taichung, Tainan, Kaohsiung
#   省轄市 (3): Keelung, Hsinchu, Chiayi
#   縣 (10):   HsinchuCounty, MiaoliCounty, ChanghuaCounty, NantouCounty,
#              YunlinCounty, ChiayiCounty, PingtungCounty, YilanCounty,
#              HualienCounty, TaitungCounty
#   離島 (3):  PenghuCounty, KinmenCounty, LienchiangCounty
# ============================================================
# BUS_ENABLED=true
# 留空使用預設的 22 縣市，或自訂清單（逗號分隔）
# BUS_CITIES=Taipei,NewTaipei,Taoyuan,Taichung,Tainan,Kaohsiung
# 全台 22 縣市 × 每 2 分鐘 = 15,840 req/日（超過 TDX 免費 10k 配額）
#   - 免費 key：調高至 BUS_INTERVAL=3 或縮減城市
#   - 付費 key（1M/日）：預設 2 分鐘即可
# BUS_INTERVAL=2
# collector 內部並行抓城市的 worker 數（避免超過 TDX rate limit）
# BUS_FETCH_WORKERS=5

# 公路客運 / 國道客運（TDX Bus/RealTimeByFrequency/InterCity，單一 endpoint）
# BUS_INTERCITY_ENABLED=false
# BUS_INTERCITY_INTERVAL=2

# 溫度網格收集間隔（分鐘）
TEMPERATURE_INTERVAL=60

# 路邊停車城市（逗號分隔）
# 支援：Taipei, NewTaipei, Taichung（高雄不支援）
PARKING_CITIES=Taipei,NewTaipei,Taichung

# 路邊停車收集間隔（分鐘）
PARKING_INTERVAL=15

# 台鐵即時列車收集間隔（分鐘）
TRA_TRAIN_INTERVAL=2

# 台鐵靜態資料收集間隔（分鐘，1440=每日一次）
TRA_STATIC_INTERVAL=1440

# 台鐵 + 高鐵每日時刻表歸檔（DailyTimetable，含停駛/加班車）
# TDX 歷史只保留 ~90 天，每日歸檔才有長期資料
RAIL_TIMETABLE_ENABLED=true
# RAIL_TIMETABLE_INTERVAL=1440

# 航運 - TDX 國內航線船位（每 2 分鐘）
SHIP_TDX_ENABLED=true
SHIP_TDX_INTERVAL=2

# 航運 - 航港局 AIS 全船型追蹤（每 2 分鐘）
SHIP_AIS_ENABLED=true
SHIP_AIS_INTERVAL=2

# OpenSky 台灣空域快照（每 5 分鐘）
# 匿名可用，帶帳號可提升至 5 秒解析度 + 4,000 credits/天
# 申請：https://opensky-network.org/
# FR24 Zone 空域快照（公開 feed，無需 API key，每 5 分鐘）
FLIGHT_FR24_ZONE_ENABLED=false
# FLIGHT_FR24_ZONE_INTERVAL=5
# bbox 可個別調整（FR24 免費，可比 OpenSky 範圍大）
# FLIGHT_FR24_ZONE_LAMIN=21
# FLIGHT_FR24_ZONE_LAMAX=27
# FLIGHT_FR24_ZONE_LOMIN=117
# FLIGHT_FR24_ZONE_LOMAX=123

# OpenSky 台灣空域快照（每 5 分鐘）
FLIGHT_OPENSKY_ENABLED=false
# FLIGHT_OPENSKY_INTERVAL=5
# OAuth2 認證（新帳號，從 Account 頁面取得 API Client）
# FLIGHT_OPENSKY_CLIENT_ID=your-api-client
# FLIGHT_OPENSKY_CLIENT_SECRET=your_client_secret
# Basic Auth（舊帳號，二擇一即可）
# FLIGHT_OPENSKY_USERNAME=your_opensky_username
# FLIGHT_OPENSKY_PASSWORD=your_opensky_password

# 衛星軌道追蹤（Space-Track.org GP + SGP4，需免費帳號，每 2 小時）
# 註冊 https://www.space-track.org/ 後填入帳密
# 活躍衛星寫入 satellite_current / satellite_positions，完整 TLE（含失效）寫入 satellite_tle
SATELLITE_ENABLED=false
# SATELLITE_INTERVAL=120
# SPACETRACK_USERNAME=your_email@example.com
# SPACETRACK_PASSWORD=your_password

# ============================================================
# 水文系列（WRA 水利署 + CWA，大多無需 API key；預設 false）
# ============================================================
# 水庫水情（WRA OpenData，每 60 分鐘）
# WATER_RESERVOIR_ENABLED=true
# WATER_RESERVOIR_INTERVAL=60

# 河川即時水位（WRA OpenData UUID 73c4c3de-...，每 10 分鐘）
# RIVER_WATER_LEVEL_ENABLED=true
# RIVER_WATER_LEVEL_INTERVAL=10

# CWA 即時雨量站 O-A0002-001（需 CWA_API_KEY，每 10 分鐘）
# RAIN_GAUGE_REALTIME_ENABLED=true
# RAIN_GAUGE_REALTIME_INTERVAL=10

# 地下水水位（WRA OpenData UUID 58a7aa39-...，每 60 分鐘，779 口觀測井）
# GROUNDWATER_LEVEL_ENABLED=true
# GROUNDWATER_LEVEL_INTERVAL=60

# 水庫每日營運狀況（WRA OpenData 41568，每日一次，官方 09:30 前更新）
# WATER_RESERVOIR_DAILY_OPS_ENABLED=true
# WATER_RESERVOIR_DAILY_OPS_INTERVAL=1440

# ============================================================
# Foursquare OS Places POI（HuggingFace gated dataset，每月全量）
# ============================================================
# 需先至 https://huggingface.co/settings/tokens 申請 token
# 並接受 dataset 使用條款：https://huggingface.co/datasets/foursquare/fsq-os-places
# FOURSQUARE_POI_ENABLED=true
# FOURSQUARE_POI_INTERVAL=43200
# HF_TOKEN=hf_your_huggingface_token
# 指定特定 release（選填，留空用最新）
# FOURSQUARE_POI_RELEASE_DT=2026-03-18

# ============================================================
# S3 儲存（建議生產環境設定）
# ============================================================
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_REGION=ap-northeast-1

# MinIO 或其他 S3 相容服務
# S3_ENDPOINT=https://minio.example.com

# S3 費用估算（日報使用；bucket 若有 Lifecycle 分層會按 class 分別計算）
# 保留介面，預設為 Standard 單價（ap-southeast-2 2026 定價，USD/GB/月）
# S3_PRICE_PER_GB=0.025
# 以下為各 storage class 的單價 overrides（有預設值，通常不需設定）
# S3_PRICE_STANDARD=0.025
# S3_PRICE_STANDARD_IA=0.0138
# S3_PRICE_GLACIER_IR=0.005
# S3_PRICE_GLACIER=0.0045
# S3_PRICE_DEEP_ARCHIVE=0.002

# ============================================================
# 通知設定（選填）
# ============================================================
# Webhook（支援 Discord、Slack 等）
# WEBHOOK_URL=https://discord.com/api/webhooks/xxx

# LINE Notify
# LINE_TOKEN=your_line_notify_token

# Telegram Bot（每日報告 + 即時錯誤通知）
# 1. 在 Telegram 找 @BotFather 建立 Bot，取得 Token
# 2. 傳訊息給你的 Bot，然後用 https://api.telegram.org/bot<TOKEN>/getUpdates 取得 Chat ID
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=123456789

# 每日報告時間（預設 08:00）
# DAILY_REPORT_TIME=08:00

# 連續錯誤告警門檻（預設 3 次）
# CONSECUTIVE_ERROR_THRESHOLD=3

# 磁碟空間告警門檻（MB，預設 8000）
# DISK_ALERT_THRESHOLD_MB=8000

# ============================================================
# HTTP API（下載資料用）
# ============================================================
# API Key（必填才會啟動 API Server）
# 建議使用隨機字串，例如：openssl rand -hex 32
API_KEY=your_api_key_here

# API 端口（預設 8080）
# API_PORT=8080

# ============================================================
# 其他
# ============================================================
# 實例名稱（多實例部署時辨識來源，例如「主站」、「AIS專機」）
# INSTANCE_NAME=主站

# DEBUG=true
# LOG_LEVEL=DEBUG
