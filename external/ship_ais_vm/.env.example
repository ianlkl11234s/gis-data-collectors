# ship_ais VM .env 範本
# 部署位置: /opt/ship-ais/.env  (chmod 600)

# ─── Supabase（必填）───
# 跟 Zeabur 同一條 URL；可用 6543 (transaction pooler) 或 5432 (session pooler)
SUPABASE_DB_URL=

# ─── S3 歸檔（必填，跟 Zeabur 同一組）───
S3_BUCKET=migu-gis-data-collector
S3_REGION=ap-southeast-2
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── 進階（可不動）───
DATA_DIR=/var/lib/ship-ais/data
ARCHIVE_RETENTION_DAYS=7
REQUEST_TIMEOUT=30
