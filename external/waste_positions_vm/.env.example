# waste_positions VM .env 範本
# 部署位置: /opt/waste-positions/.env (chmod 600)
# Tip: 與 ship_ais 共用 VM、key 完全一樣 → 可直接 cp /opt/ship-ais/.env 過來再改 DATA_DIR

# ─── Supabase（必填）───
SUPABASE_DB_URL=

# ─── S3 歸檔（必填）───
S3_BUCKET=migu-gis-data-collector
S3_REGION=ap-southeast-2
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── 進階（可不動）───
DATA_DIR=/var/lib/waste-positions/data
CITIES=Kaohsiung,NewTaipei,Tainan
QUIET_HOURS=01-06
ARCHIVE_RETENTION_DAYS=7
