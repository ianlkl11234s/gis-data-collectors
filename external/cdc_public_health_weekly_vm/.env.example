# CDC 公衛週報 VM collector .env

# Supabase pooler URL（同主 repo 用同一個 Supabase，這裡填 transaction pooler port 6543）
SUPABASE_DB_URL=postgresql://postgres.utcmcikhvxnohbxchbrs:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# 本地快照路徑（建議走 systemd 服務的 working dir）
DATA_DIR=/var/lib/cdc-public-health/data

# 保留近 N 年（預設 2 — Monitor 用近 2 年即足夠；要全歷史改成 25）
KEEP_YEARS=2
