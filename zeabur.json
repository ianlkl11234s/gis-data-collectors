{
  "$schema": "https://json-schema.zeabur.app/zeabur.json",
  "name": "data-collectors",
  "build": {
    "type": "dockerfile"
  },
  "env": {
    "TDX_APP_ID": {
      "description": "TDX API Client ID",
      "required": true
    },
    "TDX_APP_KEY": {
      "description": "TDX API Client Secret",
      "required": true
    },
    "CWA_API_KEY": {
      "description": "氣象局 API Key（選填）"
    },
    "MOENV_API_KEY": {
      "description": "環境部開放資料 API Key（空氣品質用；data.gov.tw 頁面上的公開 key 亦可）"
    },
    "AIR_QUALITY_IMAGERY_ENABLED": {
      "description": "airtw 全台空品色階圖 PNG 收集（每小時）；多實例部署時只在指定實例設 true",
      "default": "false"
    },
    "AIR_QUALITY_IMAGERY_INTERVAL": {
      "description": "airtw 色階圖收集間隔（分鐘）",
      "default": "60"
    },
    "AIR_QUALITY_ENABLED": {
      "description": "環境部 77 站即時 AQI 觀測（每小時，需 MOENV_API_KEY）",
      "default": "false"
    },
    "AIR_QUALITY_INTERVAL": {
      "description": "77 站觀測收集間隔（分鐘）",
      "default": "60"
    },
    "AIR_QUALITY_MICROSENSORS_ENABLED": {
      "description": "LASS AirBox 微型感測器（每 5 分鐘）",
      "default": "false"
    },
    "AIR_QUALITY_MICROSENSORS_INTERVAL": {
      "description": "LASS 微型感測器收集間隔（分鐘）",
      "default": "5"
    },
    "YOUBIKE_CITIES": {
      "description": "YouBike 城市（逗號分隔）",
      "default": "Taipei,NewTaipei,Taoyuan"
    },
    "YOUBIKE_INTERVAL": {
      "description": "YouBike 收集間隔（分鐘）",
      "default": "15"
    },
    "S3_BUCKET": {
      "description": "S3 儲存桶（建議設定）"
    },
    "S3_ACCESS_KEY": {
      "description": "AWS Access Key"
    },
    "S3_SECRET_KEY": {
      "description": "AWS Secret Key"
    },
    "S3_REGION": {
      "description": "AWS Region",
      "default": "ap-northeast-1"
    },
    "WEBHOOK_URL": {
      "description": "通知 Webhook URL"
    },
    "LINE_TOKEN": {
      "description": "LINE Notify Token"
    },
    "WATER_RESERVOIR_ENABLED": {
      "description": "水庫水情收集器（WRA 水利署，無需 API Key）；AIS 專屬實例設 false，其他實例設 true",
      "default": "false"
    },
    "WATER_RESERVOIR_INTERVAL": {
      "description": "水庫水情收集間隔（分鐘），對應 WRA 每小時更新頻率",
      "default": "60"
    }
  }
}
